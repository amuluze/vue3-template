    },
    "devDependencies": {
        "@antfu/eslint-config": "^3.8.0",
        "@iconify-json/ep": "^1.1.15",
        "@types/node": "^22.8.7",
        "@vitejs/plugin-vue": "^5.1.4",
        "eslint": "^9.14.0",
        "eslint-plugin-format": "^0.1.2",
        "lint-staged": "^15.2.10",
        "sass": "^1.79.5",
        "simple-git-hooks": "^2.11.1",
        "typescript": "^5.4.3",
        "unplugin-auto-import": "^0.18.3",
        "unplugin-icons": "^0.20.0",
        "unplugin-vue-components": "^0.27.4",
